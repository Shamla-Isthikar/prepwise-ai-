generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_POSTGRES")
}

model StudyPlan {
  id            String   @id @default(cuid())
  subject       String
  topics        String
  examDate      DateTime
  studyPlan     String
  createdAt     DateTime @default(now())

  userId        String
  user          User @relation(fields: [userId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  studyPlan StudyPlan[]
}